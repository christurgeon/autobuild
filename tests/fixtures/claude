#!/usr/bin/env python3
"""Stub `claude` for autobuild tests — token-free.

Invoked exactly as session.py spawns it: `claude -p <PROMPT> --model <M>`, with
cwd == the session's git worktree. It recovers the session dir and task id from
the prompt text (the contract lines build_prompt emits), makes a trivial commit
in the worktree, and writes <sdir>/result.json.

Env knobs a test sets before driving the loop:
  STUB_STATUS            COMPLETE|BLOCKED|NEEDS_HUMAN   (default COMPLETE)
  STUB_STATUS_<TID>      per-task override; '-' -> '_'  (STUB_STATUS_task_002)
  STUB_FOLLOWUPS         JSON array for result.json "followups"  (default [])
  STUB_STALL             "1" -> write NOTHING, exit 0 (simulates a dead session)
  STUB_NO_COMMIT         "1" -> skip the git commit
  STUB_STREAM            "0" -> skip the stream-json stdout transcript (default "1")
  STUB_MSGS              # of assistant events in the transcript        (default 2)
  STUB_COST              total_cost_usd in the terminal result event    (default 0.01)
  STUB_RESULT_DELAY      secs to delay the result event until AFTER result.json (default 0;
                         models real claude flushing cost after the sentinel — see #49)
"""
import json
import os
import re
import subprocess
import sys


def main():
    argv = sys.argv[1:]
    prompt = next((argv[i + 1] for i, a in enumerate(argv) if a == "-p" and i + 1 < len(argv)), None)
    if prompt is None:
        sys.stderr.write("stub-claude: no -p prompt\n")
        return 1

    m_sdir = re.search(r"session directory is:\s*(\S+)", prompt)
    m_tid = re.search(r"Work ONLY on task\s+(\S+)", prompt)
    sdir = m_sdir.group(1) if m_sdir else None
    tid = (m_tid.group(1) if m_tid else "unknown").rstrip(".")

    # Kill-path knobs (task-105): ignore SIGTERM, finish-during-grace, or just sleep.
    import signal
    import time as _time
    if os.environ.get("STUB_IGNORE_SIGTERM") == "1":
        signal.signal(signal.SIGTERM, signal.SIG_IGN)
    if os.environ.get("STUB_COMPLETE_ON_SIGTERM") == "1" and sdir:
        def _on_term(signum, frame):
            os.makedirs(sdir, exist_ok=True)
            tmp = os.path.join(sdir, "result.json.tmp")
            with open(tmp, "w") as fh:
                fh.write(json.dumps({"task": tid, "status": "COMPLETE",
                                     "summary": "finished during grace", "commit": "",
                                     "followups": []}))
            os.replace(tmp, os.path.join(sdir, "result.json"))
            os._exit(0)
        signal.signal(signal.SIGTERM, _on_term)
    sleep_s = float(os.environ.get("STUB_SLEEP", "0") or "0")
    if sleep_s:
        if sdir:  # signal readiness AFTER handlers are installed, so a test can kill safely
            os.makedirs(sdir, exist_ok=True)
            open(os.path.join(sdir, "stub-ready"), "w").close()
        _time.sleep(sleep_s)

    if os.environ.get("STUB_STALL") == "1":
        return 0  # no result.json -> the reaper's stalled path must fire

    tkey = "STUB_STATUS_" + tid.replace("-", "_")
    status = os.environ.get(tkey) or os.environ.get("STUB_STATUS", "COMPLETE")
    followups = json.loads(os.environ.get("STUB_FOLLOWUPS", "[]"))

    # STUB_LEAK_DIR (task-001 isolation): simulate a worktree escape by committing
    # straight onto base in the main checkout, instead of (only) the worktree. The
    # reaper's base_leak_commits must catch this and halt the run.
    leak_dir = os.environ.get("STUB_LEAK_DIR")
    if leak_dir:
        with open(os.path.join(leak_dir, f"leaked-{tid}.txt"), "w") as fh:
            fh.write(f"escaped session for {tid}\n")
        subprocess.run(["git", "add", "-A"], cwd=leak_dir, check=True)
        subprocess.run(["git", "commit", "-q", "-m", f"leaked {tid} onto base"],
                       cwd=leak_dir, check=True)

    commit_sha = ""
    if status == "COMPLETE" and os.environ.get("STUB_NO_COMMIT") != "1":
        cwd = os.getcwd()  # == worktree
        with open(os.path.join(cwd, f"{tid}.txt"), "a") as fh:
            fh.write(f"done by stub for {tid} pid={os.getpid()}\n")
        subprocess.run(["git", "add", "-A"], cwd=cwd, check=True)
        subprocess.run(["git", "commit", "-q", "--allow-empty", "-m", f"stub: {tid}"],
                       cwd=cwd, check=True)
        commit_sha = subprocess.run(["git", "rev-parse", "HEAD"], cwd=cwd,
                                    capture_output=True, text=True).stdout.strip()

    # Emit a stream-json transcript to stdout (the harness redirects it to session.out) so
    # the progress parser + cost budget have realistic input: an init line, STUB_MSGS
    # assistant events, then a terminal `result` event carrying STUB_COST. Emitted ONLY here
    # on the normal completion path — past the STUB_STALL early-return and STUB_SLEEP — so a
    # stalled/killed session writes no `result` event and therefore reads as 0 cost, exactly
    # like a real killed `claude`. STUB_STREAM=0 disables it (legacy text-mode behavior).
    stream = os.environ.get("STUB_STREAM", "1") == "1"
    # STUB_RESULT_DELAY models real claude's ordering: it flushes the cost-bearing `result`
    # event a moment AFTER result.json (which the harness reaps on). >0 -> emit the result
    # event AFTER the sentinel + this many seconds; 0 (default) -> synchronously before it.
    result_delay = float(os.environ.get("STUB_RESULT_DELAY", "0") or "0")
    msgs = int(os.environ.get("STUB_MSGS", "2"))
    cost = float(os.environ.get("STUB_COST", "0.01"))

    def _emit(obj):
        sys.stdout.write(json.dumps(obj) + "\n")
        sys.stdout.flush()

    def _emit_result():
        _emit({"type": "result", "subtype": "success", "num_turns": msgs,
               "total_cost_usd": cost,
               "usage": {"input_tokens": 100, "output_tokens": 20}})

    if stream:
        _emit({"type": "system", "subtype": "init", "model": "claude-stub"})
        for i in range(msgs):
            _emit({"type": "assistant",
                   "message": {"model": "claude-stub",
                               "content": [{"type": "text", "text": f"turn {i}"}]}})
        if result_delay <= 0:
            _emit_result()  # today's behavior: result event BEFORE the sentinel

    if sdir:
        os.makedirs(sdir, exist_ok=True)
        # Write atomically (temp + os.replace), mirroring the CLAUDE.md contract, so the
        # reaper never observes a torn result.json.
        payload = json.dumps({"task": tid, "status": status,
                              "summary": f"stub {status} for {tid}",
                              "commit": commit_sha, "followups": followups})
        tmp = os.path.join(sdir, "result.json.tmp")
        with open(tmp, "w") as fh:
            fh.write(payload)
        os.replace(tmp, os.path.join(sdir, "result.json"))

    if stream and result_delay > 0:
        # Flush the result event AFTER the sentinel — the harness has already reaped on
        # result.json, so this models the real flush-after-sentinel race the run-end
        # cost-settle (#49) must tolerate.
        _time.sleep(result_delay)
        _emit_result()
    return 0


if __name__ == "__main__":
    sys.exit(main())
